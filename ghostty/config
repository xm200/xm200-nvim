# --- neon fire base ---
background = #121417
background-opacity = 0.85

foreground = #FFD7A3
cursor-color = #FF6A00
cursor-text = #121417
selection-background = #4A1A00
selection-foreground = #FFE7C2

bold-is-bright = false

# --- ANSI 16-color palette (0-7 normal, 8-15 bright) ---
palette = 0=#121417
palette = 1=#FF2A00
palette = 2=#FF7A00
palette = 3=#FFB000
palette = 4=#FF5A00
