# --- colorscheme ---

# --- smooth cursor movement ---
# Ghostty does not have a native cursor-slide option yet; this shader draws
# a short fire trail between cursor positions to make jumps feel smoother.
custom-shader = cursor_smooth.glsl
custom-shader-animation = true
